# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GMAIL INTEGRATION SECRETS 
# Required for connecting the Gmail Ingestion Engine (Server-Side OAuth)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI=""
PUBSUB_TOPIC_NAME=""

# CLOUD & SECURITY SECRETS
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_SERVICE_ACCOUNT=""
GMAIL_WEBHOOK_SECRET=""
ENCRYPTION_KEY=""

# FIREBASE AUTHENTICATION SECRETS
# REQUIRED to mint Custom Tokens. Without this, /api/firebase-token will fail.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# OLLAMA ROUTING CONFIGURATION
# Used by the AI Gateway to direct primary inference to local models.
# Falls back to Gemini automatically if Ollama is unresponsive.
OLLAMA_API_URL="https://ai.hirenestworkforce.com"
OLLAMA_MODEL="llama3"

# AI CONTEXT OPTIMIZATION (pxpipe)
# Reduces LLM input tokens by converting large contexts to images.
# Useful for long RAG and internal copilot prompts, but disabled for parse-resume.
AI_CONTEXT_OPTIMIZATION=true
AI_CONTEXT_PROVIDER="pxpipe"
AI_CONTEXT_THRESHOLD=80000
